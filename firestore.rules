rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function householdId() {
      return userDoc().data.householdId;
    }

    function ownsHouseholdResource() {
      return signedIn()
        && request.resource.data.householdId is string
        && request.resource.data.householdId == householdId();
    }

    function readsHouseholdResource() {
      return signedIn()
        && resource.data.householdId is string
        && resource.data.householdId == householdId();
    }

    function writesPersonalResource() {
      return ownsHouseholdResource()
        && request.resource.data.ownerUid is string
        && request.resource.data.ownerUid == request.auth.uid;
    }

    function ownsPersonalResource() {
      return readsHouseholdResource()
        && resource.data.ownerUid is string
        && resource.data.ownerUid == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if signedIn() && (uid == request.auth.uid || resource.data.householdId == householdId());
      allow create: if signedIn() && uid == request.auth.uid;
      allow update: if signedIn() && uid == request.auth.uid;
      allow delete: if false;
    }

    match /households/{household} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read, update: if signedIn() && household == householdId();
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /{collection}/{docId} {
      allow read: if collection in [
        "incomes", "expenseCategories", "expenses", "creditCards",
        "expensePayments", "creditCardPurchases", "creditCardInstallments", "monthlyClosings"
      ] && readsHouseholdResource();

      allow create: if collection in [
        "incomes", "expenseCategories", "expenses", "creditCards",
        "expensePayments", "creditCardPurchases", "creditCardInstallments", "monthlyClosings"
      ] && writesPersonalResource();

      allow update: if collection in [
        "incomes", "expenseCategories", "expenses", "creditCards",
        "expensePayments", "creditCardPurchases", "creditCardInstallments", "monthlyClosings"
      ] && ownsPersonalResource() && writesPersonalResource();

      allow delete: if collection in [
        "incomes", "expenseCategories", "expenses", "creditCards",
        "expensePayments", "creditCardPurchases", "creditCardInstallments", "monthlyClosings"
      ] && ownsPersonalResource();

      allow read: if collection in [
        "savingsBoxes", "savingsContributions"
      ] && readsHouseholdResource();

      allow create, update: if collection in [
        "savingsBoxes", "savingsContributions"
      ] && ownsHouseholdResource();

      allow delete: if collection in [
        "savingsBoxes", "savingsContributions"
      ] && readsHouseholdResource();
    }
  }
}
